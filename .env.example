# --- Server env ---
# Postgres connection string. Local dev uses Homebrew Postgres; production
# should point at a managed service (Neon, Railway, Supabase, RDS, etc.).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/workout_app

# JWT secrets. Generate strong random values for production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production

# Port the server listens on. Hosting providers set PORT automatically.
PORT=3001

# NODE_ENV=production triggers secure cookies (sameSite=none, secure=true)
# so auth works across a separate frontend origin.
NODE_ENV=development

# Allowed frontend origin for CORS. Set to your deployed frontend URL in
# production (e.g. https://workout-app.vercel.app). Must be exact origin,
# no trailing slash.
FRONTEND_URL=http://localhost:5173

# --- Client env (prefix with VITE_ so Vite exposes it to the bundle) ---
# When unset, client assumes same-origin /api (useful in local dev via the
# Vite proxy). In production set this to the deployed server URL, e.g.
# https://workout-api.up.railway.app/api
# VITE_API_URL=
