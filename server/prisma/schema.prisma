generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UnitPreference {
  kg
  lb
}

enum Theme {
  light
  dark
  system
}

enum RecordType {
  max_weight
  max_reps
  max_volume
  est_1rm
}

enum GoalType {
  workouts_per_week
  exercise_target
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  passwordHash   String         @map("password_hash")
  name           String         @db.VarChar(100)
  avatarUrl      String?        @map("avatar_url")
  unitPreference UnitPreference @default(lb) @map("unit_preference")
  theme          Theme          @default(system)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  exercises       Exercise[]
  routines        Routine[]
  workouts        Workout[]
  personalRecords PersonalRecord[]
  bodyweightLogs  BodyweightLog[]
  goals           Goal[]

  @@map("users")
}

model Exercise {
  id               String   @id @default(uuid())
  userId           String?  @map("user_id")
  name             String   @db.VarChar(100)
  muscleGroup      String   @map("muscle_group") @db.VarChar(50)
  secondaryMuscles String[] @map("secondary_muscles")
  equipment        String?  @db.VarChar(50)
  isCustom         Boolean  @default(false) @map("is_custom")
  createdAt        DateTime @default(now()) @map("created_at")

  user             User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  routineExercises RoutineExercise[]
  workoutExercises WorkoutExercise[]
  personalRecords  PersonalRecord[]
  goals            Goal[]

  @@index([userId])
  @@map("exercises")
}

model Routine {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  name       String    @db.VarChar(100)
  tags       String[]
  isFavorite Boolean   @default(false) @map("is_favorite")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises RoutineExercise[]
  workouts  Workout[]

  @@map("routines")
}

model RoutineExercise {
  id            String   @id @default(uuid())
  routineId     String   @map("routine_id")
  exerciseId    String   @map("exercise_id")
  sortOrder     Int      @map("sort_order")
  defaultSets   Int      @default(3) @map("default_sets")
  defaultReps   Int      @default(10) @map("default_reps")
  defaultWeight Decimal? @map("default_weight") @db.Decimal(10, 2)
  restSeconds   Int      @default(90) @map("rest_seconds")

  routine  Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@map("routine_exercises")
}

model Workout {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  routineId       String?   @map("routine_id")
  name            String    @db.VarChar(100)
  date            DateTime  @db.Date
  startedAt       DateTime  @default(now()) @map("started_at")
  completedAt     DateTime? @map("completed_at")
  durationMinutes Int?      @map("duration_minutes")
  notes           String?
  tags            String[]
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  routine   Routine?          @relation(fields: [routineId], references: [id], onDelete: SetNull)
  exercises WorkoutExercise[]

  @@index([userId, date])
  @@map("workouts")
}

model WorkoutExercise {
  id         String  @id @default(uuid())
  workoutId  String  @map("workout_id")
  exerciseId String  @map("exercise_id")
  sortOrder  Int     @map("sort_order")
  notes      String?

  workout  Workout      @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise     @relation(fields: [exerciseId], references: [id])
  sets     WorkoutSet[]

  @@map("workout_exercises")
}

model WorkoutSet {
  id                String   @id @default(uuid())
  workoutExerciseId String   @map("workout_exercise_id")
  setNumber         Int      @map("set_number")
  weight            Decimal? @db.Decimal(10, 2)
  reps              Int?
  rpe               Decimal? @db.Decimal(3, 1)
  isWarmup          Boolean  @default(false) @map("is_warmup")
  isDropset         Boolean  @default(false) @map("is_dropset")
  isPr              Boolean  @default(false) @map("is_pr")

  workoutExercise WorkoutExercise  @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  personalRecords PersonalRecord[]

  @@map("workout_sets")
}

model PersonalRecord {
  id           String     @id @default(uuid())
  userId       String     @map("user_id")
  exerciseId   String     @map("exercise_id")
  workoutSetId String?    @map("workout_set_id")
  recordType   RecordType @map("record_type")
  value        Decimal    @db.Decimal(10, 2)
  achievedAt   DateTime   @map("achieved_at") @db.Date
  createdAt    DateTime   @default(now()) @map("created_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise    Exercise    @relation(fields: [exerciseId], references: [id])
  workoutSet  WorkoutSet? @relation(fields: [workoutSetId], references: [id], onDelete: SetNull)

  @@index([userId, exerciseId, recordType])
  @@map("personal_records")
}

model BodyweightLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  weight    Decimal  @db.Decimal(6, 2)
  date      DateTime @db.Date
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("bodyweight_logs")
}

model Goal {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  type         GoalType
  targetValue  Int      @map("target_value")
  exerciseId   String?  @map("exercise_id")
  targetWeight Decimal? @map("target_weight") @db.Decimal(10, 2)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise? @relation(fields: [exerciseId], references: [id])

  @@map("goals")
}
